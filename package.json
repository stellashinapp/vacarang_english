{
  "name": "oxford-word-play",
  "version": "1.0.0",
  "description": "Oxford 3000 기반 영어 단어 학습 게임",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "adb:reverse": "powershell -ExecutionPolicy Bypass -File ./adb-reverse.ps1",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build -p android --profile production",
    "build:apk": "npx eas-cli build -p android --profile preview",
    "build:apk:clear": "npx eas-cli build -p android --profile preview --clear-cache",
    "build:ios": "eas build -p ios --profile production",
    "submit:android": "eas submit -p android",
    "submit:ios": "eas submit -p ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-build-properties": "~0.13.3",
    "expo-font": "~13.0.0",
    "expo-haptics": "~14.0.1",
    "expo-linear-gradient": "~14.0.2",
    "expo-speech": "~13.0.1",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-safe-area-context": "4.12.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.3"
  },
  "private": true
}
