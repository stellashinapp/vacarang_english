{
  "name": "oxford-word-play",
  "version": "1.0.0",
  "description": "Oxford 3000 기반 영어 단어 학습 게임",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "adb:reverse": "powershell -ExecutionPolicy Bypass -File ./adb-reverse.ps1",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:8083": "expo start --web --port 8083",
    "build:android": "eas build -p android --profile production",
    "build:apk": "npx eas-cli build -p android --profile preview",
    "build:apk:clear": "npx eas-cli build -p android --profile preview --clear-cache",
    "build:ios": "eas build -p ios --profile production",
    "submit:android": "eas submit -p android",
    "submit:ios": "eas submit -p ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.5",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-firebase/analytics": "^23.8.6",
    "@react-native-firebase/app": "^23.8.6",
    "expo": "^53.0.0",
    "expo-asset": "~11.1.7",
    "expo-av": "~15.1.7",
    "expo-build-properties": "~0.14.8",
    "expo-dev-client": "~5.2.4",
    "expo-font": "~13.3.2",
    "expo-haptics": "~14.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-speech": "~13.1.7",
    "expo-status-bar": "~2.2.3",
    "expo-store-review": "~8.1.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-google-mobile-ads": "^14.11.0",
    "react-native-purchases": "^10.0.1",
    "react-native-safe-area-context": "5.4.0",
    "react-native-web": "^0.20.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/ngrok": "^4.1.3"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "@react-native-async-storage/async-storage"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av"
        ]
      }
    }
  }
}
